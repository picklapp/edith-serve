<% var page = 'dashboard'; var title = 'Dashboard'; %>
<%- include('layout-head') %>

    <div class="topbar">
      <h2>Gateway Dashboard</h2>
      <div class="topbar-right">
        <span class="status-dot"></span>
        <span style="font-size: 13px; color: #4caf50;">Gateway Active</span>
      </div>
    </div>

    <div class="content">
      <!-- Stats -->
      <div class="stat-grid">
        <div class="stat-card">
          <div class="stat-label">Identity Providers</div>
          <div class="stat-value"><%= stats.activeIdps %></div>
          <div class="stat-sub">SSO into Edith Core</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Service Providers</div>
          <div class="stat-value"><%= stats.activeSpps + stats.configuredSps %></div>
          <div class="stat-sub"><%= stats.activeSpps %> active, <%= stats.configuredSps %> configured</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">SAML Routes</div>
          <div class="stat-value"><%= stats.totalRoutes %></div>
          <div class="stat-sub"><%= stats.inboundRoutes %> inbound, <%= stats.outboundRoutes %> outbound</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Assertions Logged</div>
          <div class="stat-value"><%= recentLogs.length > 0 ? recentLogs.length : '0' %></div>
          <div class="stat-sub">This session</div>
        </div>
      </div>

      <!-- Architecture Overview -->
      <div class="card">
        <div class="card-header">
          <h3>Gateway Architecture</h3>
        </div>
        <div class="card-body" style="text-align: center; padding: 30px;">
          <div style="display: flex; align-items: center; justify-content: center; gap: 40px; flex-wrap: wrap;">
            <!-- IdPs column -->
            <div style="text-align: center;">
              <div style="font-size: 12px; color: #29b6f6; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 12px;">
                Identity Providers (<%= config.idpProviders.length %>)
              </div>
              <% config.idpProviders.forEach(function(idp) { %>
              <div style="background: #1b2d3a; border: 1px solid #29b6f6; border-radius: 6px; padding: 8px 16px; margin: 6px 0; font-size: 13px; color: #29b6f6;">
                <%= idp.name %>
              </div>
              <% }); %>
            </div>

            <!-- Arrow -->
            <div style="font-size: 24px; color: #29b6f6;">&#8594;</div>

            <!-- Gateway -->
            <div style="text-align: center;">
              <div style="background: #2a1b3a; border: 2px solid #7c8aff; border-radius: 10px; padding: 24px 32px;">
                <div style="font-size: 11px; color: #666; text-transform: uppercase; letter-spacing: 1px;">SAML Proxy</div>
                <div style="font-size: 18px; font-weight: 700; color: #7c8aff; margin-top: 4px;">Gateway</div>
                <div style="font-size: 11px; color: #888; margin-top: 8px;">:6000</div>
                <div style="font-size: 10px; color: #555; margin-top: 4px;">Validates &middot; Signs &middot; Routes</div>
              </div>
              <div style="margin-top: 8px; font-size: 11px; color: #555;">
                &#8593; Edith Core Backend :9090 &#8593;
              </div>
            </div>

            <!-- Arrow -->
            <div style="font-size: 24px; color: #ab47bc;">&#8594;</div>

            <!-- SPs column -->
            <div style="text-align: center; max-height: 400px; overflow-y: auto;">
              <div style="font-size: 12px; color: #ab47bc; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 12px;">
                Service Providers (<%= config.spProviders.length %>)
              </div>
              <% config.spProviders.forEach(function(sp) { %>
              <div style="background: #2d1b3a; border: 1px solid <%= sp.status === 'active' ? '#ab47bc' : '#555' %>; border-radius: 6px; padding: 8px 16px; margin: 6px 0; font-size: 13px; color: <%= sp.status === 'active' ? '#ab47bc' : '#666' %>;">
                <%= sp.name %> <% if (sp.status !== 'active') { %><span style="font-size: 10px; color: #ff9800;">(cfg)</span><% } %>
              </div>
              <% }); %>
            </div>
          </div>
        </div>
      </div>

      <!-- Recent Assertion Log -->
      <div class="card">
        <div class="card-header">
          <h3>Recent Assertion Flow</h3>
          <a href="/logs" style="font-size: 13px; color: #7c8aff; text-decoration: none;">View All &#8594;</a>
        </div>
        <div class="card-body">
          <% if (recentLogs.length === 0) { %>
          <div class="empty-state">
            <div class="empty-icon">&#8644;</div>
            <p>No SAML assertions have flowed through the gateway yet.</p>
            <p style="font-size: 12px; margin-top: 8px; color: #444;">Assertions will appear here when IdPs or SPs send SAML traffic through the gateway proxy.</p>
          </div>
          <% } else { %>
          <table>
            <thead>
              <tr>
                <th>Time</th>
                <th>Direction</th>
                <th>From</th>
                <th>To</th>
                <th>User</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              <% recentLogs.forEach(function(log) { %>
              <tr>
                <td style="font-size: 12px; color: #666;"><%= new Date(log.timestamp).toLocaleTimeString() %></td>
                <td><span class="badge badge-<%= log.direction %>"><%= log.direction %></span></td>
                <td><%= log.from %></td>
                <td><%= log.to %></td>
                <td><%= log.user || '-' %></td>
                <td><span class="badge badge-<%= log.status %>"><%= log.status %></span></td>
              </tr>
              <% }); %>
            </tbody>
          </table>
          <% } %>
        </div>
      </div>
    </div>

<%- include('layout-foot') %>
