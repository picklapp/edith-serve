<% var page = 'topology'; var title = 'Topology'; %>
<%- include('layout-head') %>

    <div class="topbar">
      <h2>System Topology</h2>
      <div class="topbar-right">
        <button onclick="refreshHealth()" style="background: #2a2d3a; border: 1px solid #3a3d4a; color: #e0e0e0; padding: 6px 16px; border-radius: 4px; cursor: pointer; font-size: 13px;">
          Refresh Health
        </button>
      </div>
    </div>

    <div class="content">
      <!-- Visual topology map -->
      <div class="card">
        <div class="card-header">
          <h3>SAML Federation Topology</h3>
          <span style="font-size: 12px; color: #666;">All systems connected through the SAML Gateway proxy</span>
        </div>
        <div class="card-body">
          <div style="overflow-x: auto;">
            <svg viewBox="0 0 1100 600" style="width: 100%; max-width: 1100px; margin: 0 auto; display: block;">
              <!-- Background -->
              <rect width="1100" height="600" fill="#0f1117" rx="8"/>

              <!-- IdP zone -->
              <rect x="20" y="20" width="280" height="560" rx="8" fill="#0d1520" stroke="#1b2d3a" stroke-width="1"/>
              <text x="160" y="50" fill="#29b6f6" text-anchor="middle" font-size="13" font-weight="600">IDENTITY PROVIDERS (Inbound)</text>

              <!-- IdP boxes -->
              <% config.idpProviders.forEach(function(idp, i) { %>
              <rect x="40" y="<%= 70 + i * 80 %>" width="240" height="60" rx="6" fill="#1b2d3a" stroke="#29b6f6" stroke-width="1"/>
              <text x="160" y="<%= 97 + i * 80 %>" fill="#29b6f6" text-anchor="middle" font-size="12" font-weight="600"><%= idp.name %></text>
              <text x="160" y="<%= 115 + i * 80 %>" fill="#555" text-anchor="middle" font-size="9"><%= idp.status === 'active' ? 'ACTIVE' : 'CONFIGURED' %></text>
              <!-- Arrow from IdP to Gateway -->
              <line x1="280" y1="<%= 100 + i * 80 %>" x2="420" y2="300" stroke="#29b6f6" stroke-width="1" stroke-dasharray="4,4" opacity="0.5"/>
              <% }); %>

              <!-- Gateway (center) -->
              <rect x="420" y="220" width="260" height="160" rx="12" fill="#1a1040" stroke="#7c8aff" stroke-width="2"/>
              <text x="550" y="260" fill="#7c8aff" text-anchor="middle" font-size="10" font-weight="600" letter-spacing="2">SAML PROXY</text>
              <text x="550" y="290" fill="#e0e0e0" text-anchor="middle" font-size="18" font-weight="700">Gateway</text>
              <text x="550" y="315" fill="#888" text-anchor="middle" font-size="11">localhost:6000</text>
              <text x="550" y="340" fill="#555" text-anchor="middle" font-size="10">Validates | Signs | Routes</text>
              <text x="550" y="360" fill="#555" text-anchor="middle" font-size="10">Core Backend :9090</text>

              <!-- SP zone -->
              <rect x="800" y="20" width="280" height="560" rx="8" fill="#150d20" stroke="#2d1b3a" stroke-width="1"/>
              <text x="940" y="50" fill="#ab47bc" text-anchor="middle" font-size="13" font-weight="600">SERVICE PROVIDERS (Outbound)</text>

              <!-- SP boxes (show first 9 + overflow indicator) -->
              <% var displaySps = config.spProviders.slice(0, 9); %>
              <% displaySps.forEach(function(sp, i) { %>
              <rect x="820" y="<%= 65 + i * 52 %>" width="240" height="38" rx="6" fill="<%= sp.status === 'active' ? '#2d1b3a' : '#1a1020' %>" stroke="<%= sp.status === 'active' ? '#ab47bc' : '#444' %>" stroke-width="1"/>
              <text x="940" y="<%= 88 + i * 52 %>" fill="<%= sp.status === 'active' ? '#ab47bc' : '#666' %>" text-anchor="middle" font-size="11" font-weight="600"><%= sp.name %></text>
              <!-- Arrow from Gateway to SP -->
              <line x1="680" y1="300" x2="820" y2="<%= 84 + i * 52 %>" stroke="#ab47bc" stroke-width="1" stroke-dasharray="4,4" opacity="0.4"/>
              <% }); %>

              <% if (config.spProviders.length > 9) { %>
              <text x="940" y="<%= 88 + 9 * 52 %>" fill="#666" text-anchor="middle" font-size="11">+ <%= config.spProviders.length - 9 %> more service providers</text>
              <% } %>

              <!-- Flow labels -->
              <text x="370" y="200" fill="#29b6f6" text-anchor="middle" font-size="10" transform="rotate(-15, 370, 200)">SAMLResponse</text>
              <text x="730" y="200" fill="#ab47bc" text-anchor="middle" font-size="10" transform="rotate(15, 730, 200)">SAMLResponse</text>
            </svg>
          </div>
        </div>
      </div>

      <!-- Health status -->
      <div class="card">
        <div class="card-header">
          <h3>Service Health</h3>
          <span id="health-status" style="font-size: 12px; color: #666;">Click "Refresh Health" to check</span>
        </div>
        <div class="card-body">
          <div id="health-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 12px;">
            <% config.idpProviders.filter(function(p) { return p.uiUrl; }).forEach(function(idp) { %>
            <div class="health-item" data-id="<%= idp.id %>" style="background: #1a1c2a; border: 1px solid #2a2d3a; border-radius: 6px; padding: 12px; display: flex; justify-content: space-between; align-items: center;">
              <div>
                <div style="font-size: 13px; font-weight: 600;"><%= idp.name %></div>
                <div style="font-size: 11px; color: #555;"><%= idp.uiUrl %></div>
              </div>
              <span class="badge badge-idp" style="font-size: 10px;">IdP</span>
            </div>
            <% }); %>
            <% config.spProviders.filter(function(p) { return p.uiUrl; }).forEach(function(sp) { %>
            <div class="health-item" data-id="<%= sp.id %>" style="background: #1a1c2a; border: 1px solid #2a2d3a; border-radius: 6px; padding: 12px; display: flex; justify-content: space-between; align-items: center;">
              <div>
                <div style="font-size: 13px; font-weight: 600;"><%= sp.name %></div>
                <div style="font-size: 11px; color: #555;"><%= sp.uiUrl %></div>
              </div>
              <span class="badge badge-sp" style="font-size: 10px;">SP</span>
            </div>
            <% }); %>
          </div>
        </div>
      </div>

      <!-- Connection matrix -->
      <div class="card">
        <div class="card-header">
          <h3>Connection Matrix</h3>
          <span style="font-size: 12px; color: #666;">Which IdPs can reach which SPs through the gateway</span>
        </div>
        <div class="card-body" style="overflow-x: auto;">
          <table style="font-size: 12px;">
            <thead>
              <tr>
                <th>IdP \ SP</th>
                <% config.spProviders.slice(0, 10).forEach(function(sp) { %>
                <th style="text-align: center; padding: 6px; writing-mode: vertical-lr; transform: rotate(180deg); height: 80px;"><%= sp.name %></th>
                <% }); %>
              </tr>
            </thead>
            <tbody>
              <% config.idpProviders.forEach(function(idp) { %>
              <tr>
                <td style="font-weight: 600; white-space: nowrap;"><%= idp.name %></td>
                <% config.spProviders.slice(0, 10).forEach(function(sp) { %>
                <td style="text-align: center;">
                  <span style="color: #4caf50; font-size: 14px;" title="<%= idp.name %> -> Core -> <%= sp.name %>">&#10003;</span>
                </td>
                <% }); %>
              </tr>
              <% }); %>
              <tr>
                <td style="font-weight: 600; color: #7c8aff;">Edith Core (direct)</td>
                <% config.spProviders.slice(0, 10).forEach(function(sp) { %>
                <td style="text-align: center;">
                  <span style="color: #7c8aff; font-size: 14px;">&#10003;</span>
                </td>
                <% }); %>
              </tr>
            </tbody>
          </table>
          <% if (config.spProviders.length > 10) { %>
          <p style="font-size: 11px; color: #555; margin-top: 12px;">Showing first 10 of <%= config.spProviders.length %> service providers. All IdPs can chain-SSO to all SPs through the gateway.</p>
          <% } %>
        </div>
      </div>
    </div>

    <script>
      async function refreshHealth() {
        document.getElementById('health-status').textContent = 'Checking...';
        try {
          const res = await fetch('/api/health');
          const data = await res.json();
          data.services.forEach(function(svc) {
            const el = document.querySelector('[data-id="' + svc.id + '"]');
            if (el) {
              el.style.borderColor = svc.status === 'up' ? '#4caf50' : '#f44336';
              var badge = el.querySelector('.badge');
              if (badge) {
                badge.textContent = svc.status === 'up' ? 'UP' : 'DOWN';
                badge.style.background = svc.status === 'up' ? '#1b3a2d' : '#3a1b1b';
                badge.style.color = svc.status === 'up' ? '#4caf50' : '#f44336';
              }
            }
          });
          document.getElementById('health-status').textContent = 'Last checked: ' + new Date().toLocaleTimeString();
        } catch (err) {
          document.getElementById('health-status').textContent = 'Health check failed';
        }
      }
    </script>

<%- include('layout-foot') %>
