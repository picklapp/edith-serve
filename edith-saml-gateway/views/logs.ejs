<% var page = 'logs'; var title = 'Assertion Log'; %>
<%- include('layout-head') %>

    <div class="topbar">
      <h2>Assertion Log</h2>
      <div class="topbar-right">
        <span style="font-size: 13px; color: #888;"><%= logs.length %> entries</span>
      </div>
    </div>

    <div class="content">
      <div class="tabs">
        <a href="/logs?direction=all" class="tab <%= direction === 'all' ? 'active' : '' %>">All</a>
        <a href="/logs?direction=inbound" class="tab <%= direction === 'inbound' ? 'active' : '' %>">Inbound</a>
        <a href="/logs?direction=outbound" class="tab <%= direction === 'outbound' ? 'active' : '' %>">Outbound</a>
      </div>

      <div class="card">
        <div class="card-body" style="padding: 0;">
          <% if (logs.length === 0) { %>
          <div class="empty-state">
            <div class="empty-icon">&#9776;</div>
            <p>No assertion events recorded yet.</p>
            <p style="font-size: 12px; margin-top: 8px; color: #444;">
              SAML assertions flowing through the gateway proxy (port 6000) will be logged here.<br/>
              Try SSO from a bank portal or from the Core dashboard to see entries appear.
            </p>
          </div>
          <% } else { %>
          <table>
            <thead>
              <tr>
                <th>Timestamp</th>
                <th>ID</th>
                <th>Direction</th>
                <th>From</th>
                <th>To</th>
                <th>User</th>
                <th>Display Name</th>
                <th>Status</th>
                <th>Details</th>
              </tr>
            </thead>
            <tbody>
              <% logs.forEach(function(log) { %>
              <tr>
                <td style="font-size: 12px; color: #666; white-space: nowrap;"><%= log.timestamp %></td>
                <td style="font-size: 11px; color: #555; font-family: monospace;"><%= log.id.slice(0, 16) %></td>
                <td><span class="badge badge-<%= log.direction %>"><%= log.direction %></span></td>
                <td><%= log.from %></td>
                <td><%= log.to %></td>
                <td><%= log.user || '-' %></td>
                <td><%= log.displayName || '-' %></td>
                <td><span class="badge badge-<%= log.status %>"><%= log.status %></span></td>
                <td style="font-size: 11px; color: #555;">
                  <% if (log.error) { %><span style="color: #f44336;"><%= log.error %></span><% } %>
                  <% if (log.acsUrl) { %><span>ACS: <%= log.acsUrl %></span><% } %>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
          <% } %>
        </div>
      </div>
    </div>

    <script>
      // Auto-refresh every 5 seconds
      setInterval(function() {
        fetch('/api/logs?limit=50')
          .then(function(res) { return res.json(); })
          .then(function(data) {
            if (data.logs.length > 0) {
              location.reload();
            }
          })
          .catch(function() {});
      }, 5000);
    </script>

<%- include('layout-foot') %>
